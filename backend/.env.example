# App
APP_SECRET_KEY=change_me_in_production_use_random_32_chars
APP_DEBUG=false
APP_BASE_URL=https://skynet.example.com
APP_HTTPS_MODE=edge
APP_HTTPS_PROVIDER=reverse_proxy
APP_TRUST_PROXY_HEADERS=true
APP_HSTS_ENABLED=true

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://skynet:skynet@localhost:5432/skynet

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=change_me_jwt_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# GeoIP (MaxMind)
GEOIP_DB_PATH=./data/GeoLite2-City.mmdb

# CORS
CORS_ORIGINS=https://skynet.example.com,http://localhost:5173,http://localhost:3000

# Keycloak — external IdP for end-user JWT validation (NOT for SKYNET operator login)
# SKYNET operators always authenticate locally (username + password).
# Set these to enable /api/v1/identity/link and /track/activity endpoints.
# These values can also be configured at runtime via Settings → Auth.
KEYCLOAK_JWKS_URL=http://10.0.0.39:8080/realms/Mouwaten/protocol/openid-connect/certs
KEYCLOAK_ISSUER=https://auth.mouwaten.org/realms/Mouwaten
KEYCLOAK_AUDIENCE=mouwaten-web
KEYCLOAK_CACHE_TTL_SEC=300
KEYCLOAK_SYNC_BASE_URL=http://10.0.0.39:8080
KEYCLOAK_SYNC_REALM=Mouwaten
KEYCLOAK_SYNC_CLIENT_ID=admin-cli
KEYCLOAK_SYNC_CLIENT_SECRET=
KEYCLOAK_SYNC_USERNAME=admin
KEYCLOAK_SYNC_PASSWORD=change-me-now
